# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Auth - comma-separated passphrases per tier
FREE_PASSPHRASES=free-pass-1,free-pass-2
PRO_PASSPHRASES=pro-pass-1,pro-pass-2
MAX_PASSPHRASES=max-pass-1,max-pass-2

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# yt-dlp binary path (leave empty to use system PATH)
YTDLP_PATH=
