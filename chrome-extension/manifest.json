{
  "manifest_version": 3,
  "name": "Maverick - Audio Downloader",
  "version": "1.0.0",
  "description": "Download audio from YouTube, SoundCloud, TikTok & more in 320kbps MP3",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maverick Audio Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": []
}
